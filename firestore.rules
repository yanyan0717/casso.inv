rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - each user can only access their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Approved devices subcollection
      match /devices/{deviceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Pending approvals subcollection
      match /pendingApprovals/{deviceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Other collections (existing ones from your app)
    match /profiles/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == request.auth.uid;
    }
    
    // Add your other collection rules here as needed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
